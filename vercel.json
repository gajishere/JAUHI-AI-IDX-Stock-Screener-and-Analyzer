{
  "rewrites": [
    {
      "source": "/anthropic/:path*",
      "destination": "/api/anthropic?path=/:path*"
    },
    {
      "source": "/yf/:path*",
      "destination": "https://query1.finance.yahoo.com/:path*"
    },
    {
      "source": "/idx/:path*",
      "destination": "/api/idx?path=/:path*"
    }
  ]
}
