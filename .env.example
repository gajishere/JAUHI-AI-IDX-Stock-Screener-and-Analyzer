# Claude AI API Key for enhanced analysis
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# IDX RapidAPI key — live Indonesia Stock Exchange data (broker tape, bandarmology).
# Subscribe at https://rapidapi.com/ (Indonesia Stock Exchange (IDX) API), then
# copy the X-RapidAPI-Key here. NO VITE_ prefix: the dev proxy injects it
# server-side via the /idx route so it is never exposed to the browser.
IDX_RAPIDAPI_KEY=your_rapidapi_key_here

# --- Live Auto-Screening (server-side cron scan) ---
# Shared secret the external scheduler (GitHub Actions) sends as a Bearer token
# to /api/auto-screen-run. Set the SAME value as a Vercel env var AND a GitHub
# repo secret (AUTO_SCREEN_TOKEN). Generate one with: openssl rand -hex 32
AUTO_SCREEN_TOKEN=your_long_random_token_here

# Vercel Blob store read/write token — stores the latest scan snapshot. On Vercel
# this is auto-injected when you connect a Blob store (Storage tab); only set it
# here if running the serverless functions locally against a real store.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: absolute origin the Node scan uses to reach its own /idx + /yf
# proxies. Auto-derived from VERCEL_URL in production; defaults to
# http://localhost:5177 for local `node` runs. Override only if needed.
# SELF_ORIGIN=https://your-app.vercel.app